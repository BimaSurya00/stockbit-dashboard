# Container port (app listen di port ini)
PORT=3001

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/stockbit_dashboard

# Copy dari browser network tab setelah login ke stockbit.com
# Lihat di Network > Request Headers > authorization (Bearer token)
STOCKBIT_TOKEN=your_jwt_bearer_token_here
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36
